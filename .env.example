# Required: Perplexity Sonar API key for historical research
VITE_PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: OpenRouter API key for image generation (Gemini Nano Banana via OpenRouter)
VITE_OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: Mapbox access token for the map
VITE_MAPBOX_TOKEN=pk.eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: Override the default Nano Banana model on OpenRouter
# Options: google/gemini-3-pro-image-preview (Pro), google/gemini-3.1-flash-image-preview (Flash), google/gemini-2.5-flash-image (default)
# VITE_IMAGE_MODEL=google/gemini-2.5-flash-image
